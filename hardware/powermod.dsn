    )
    (net RTC_SDA
      (pins U2-17 U1-5 R17-2)
    )
    (net RTC_VDD
      (pins U1-8 C13-1 D3-1 D4-1)
    )
    (net SCL
      (pins U2-16 J4-4)
    )
    (net SDA
      (pins U2-15 J4-3)
    )
    (net UPDI
      (pins U2-23 J5-1)
    )
    (net VBACKUP
      (pins D4-2 TP1-1 JP1-2)
    )
    (net VBAT
      (pins U4-5 C6-1 Q2-5 Q2-6 Q2-7 Q2-8 J3-1 TP2-1 R6-1)
    )
    (net VBAT_DIV
      (pins R6-2 R7-1 C10-1 U2-5)
    )
    (net VBUS
      (pins J1-A4 J1-A9 J1-B4 J1-B9 C7-1 C15-1 R12-1 U4-4 Q1-5 Q1-6 Q1-7 Q1-8 Q2-4
        R8-1)
    )
    (net VBUS_DIV
      (pins R8-2 R9-1 C11-1 U2-6)
    )
    (net VOUT
      (pins J2-A4 J2-A9 J2-B4 J2-B9 U3-4 U3-5 C3-1 C4-1 C5-1 R26-2 JP2-2 TP3-1 R4-2
        R5-2)
    )
    (net VSYS
      (pins Q1-1 Q1-2 Q1-3 Q2-1 Q2-2 Q2-3 R10-1 C12-1 U3-1 U3-10 U3-11 C1-1 C2-1 C16-1
        U5-3 C8-1)
    )
    (class kicad_default 3V3 BUTTON CC1_IN CC1_OUT CC2_IN CC2_OUT CHG_CE CHG_CHRG
      CHG_JP CHG_STDBY CONV_EN D1_GRN D1_RED D2_GRN D2_RED FB FB_MID GND L1N
      L2 LED_BAT_A LED_BAT_B LED_PWR_A LED_PWR_B OSCI OSCO PROG Q1_GATE Q1_GATE_DRV
      Q3_DRAIN RTC_INT RTC_SCL RTC_SDA RTC_VDD SCL SDA UPDI VBACKUP VBAT VBAT_DIV
      VBUS VBUS_DIV VOUT VSYS
      (circuit
